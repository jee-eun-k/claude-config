{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "CLAUDE_AUDIT_ENABLED": "true",
    "CLAUDE_TRACE_ENABLED": "true"
  },
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Bash(gh *)",
      "WebSearch",
      "WebFetch",
      "mcp__infra-gateway__search",
      "mcp__infra-gateway__search_code",
      "mcp__infra-gateway__search_repositories",
      "mcp__infra-gateway__fetch_content"
    ],
    "defaultMode": "plan"
  },
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": true,
    "oh-my-claudecode@oh-my-claudecode": true,
    "superpowers@claude-plugins-official": true,
    "warp@claude-code-warp": false
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "docker",
      "git"
    ]
  },
  "lazyLoadMcpTools": true,
  "mcpServers": {
    "ticktick": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "/Users/alexa/Development/999.__personal__/ticktick-mcp",
        "-m",
        "ticktick_mcp.cli",
        "run"
      ]
    }
  },
  "theme": "light-daltonized"
}
